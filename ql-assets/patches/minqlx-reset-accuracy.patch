+/*
+* ================================================================
+*                       reset_player_stats
+* ================================================================
+*/
+
+static PyObject* PyMinqlx_ResetPlayerStats(PyObject* self, PyObject* args) {
+    int client_id;
+    if (!PyArg_ParseTuple(args, "i:reset_player_stats", &client_id))
+        return NULL;
+    else if (client_id < 0 || client_id >= sv_maxclients->integer) {
+        PyErr_Format(PyExc_ValueError,
+                     "client_id needs to be a number from 0 to %d.",
+                     sv_maxclients->integer);
+        return NULL;
+    }
+    else if (!g_entities[client_id].client)
+        Py_RETURN_FALSE;
+
+    g_entities[client_id].client->accuracy_shots = 0;
+    g_entities[client_id].client->accuracy_hits = 0;
+    g_entities[client_id].client->round_shots = 0;
+    g_entities[client_id].client->round_hits = 0;
+    g_entities[client_id].client->expandedStats.numKills = 0;
+    g_entities[client_id].client->expandedStats.numDeaths = 0;
+    for (int i = 0; i < 16; i++) {
+        g_entities[client_id].client->expandedStats.shotsFired[i] = 0;
+        g_entities[client_id].client->expandedStats.shotsHit[i] = 0;
+    }
+    Py_RETURN_TRUE;
+}
+
+/*
+* ================================================================
+*                       reset_player_accuracy
+* ================================================================
+*/
+
+static PyObject* PyMinqlx_ResetPlayerAccuracy(PyObject* self, PyObject* args) {
+    int client_id;
+    if (!PyArg_ParseTuple(args, "i:reset_player_accuracy", &client_id))
+        return NULL;
+    else if (client_id < 0 || client_id >= sv_maxclients->integer) {
+        PyErr_Format(PyExc_ValueError,
+                     "client_id needs to be a number from 0 to %d.",
+                     sv_maxclients->integer);
+        return NULL;
+    }
+    else if (!g_entities[client_id].client)
+        Py_RETURN_FALSE;
+
+    g_entities[client_id].client->accuracy_shots = 0;
+    g_entities[client_id].client->accuracy_hits = 0;
+    g_entities[client_id].client->round_shots = 0;
+    g_entities[client_id].client->round_hits = 0;
+    for (int i = 0; i < 16; i++) {
+        g_entities[client_id].client->expandedStats.shotsFired[i] = 0;
+        g_entities[client_id].client->expandedStats.shotsHit[i] = 0;
+    }
+    Py_RETURN_TRUE;
+}
+
+/*
+* ================================================================
+*                       player_accuracy
+* ================================================================
+*/
+
+static PyObject* PyMinqlx_PlayerAccuracy(PyObject* self, PyObject* args) {
+    int client_id;
+    if (!PyArg_ParseTuple(args, "i:player_accuracy", &client_id))
+        return NULL;
+    else if (client_id < 0 || client_id >= sv_maxclients->integer) {
+        PyErr_Format(PyExc_ValueError,
+                     "client_id needs to be a number from 0 to %d.",
+                     sv_maxclients->integer);
+        return NULL;
+    }
+    else if (!g_entities[client_id].client)
+        Py_RETURN_NONE;
+
+    return Py_BuildValue("(ii)", g_entities[client_id].client->accuracy_hits,
+                                 g_entities[client_id].client->accuracy_shots);
+}
