#!/usr/bin/env bash
set -euo pipefail

CONFIG_PATH="${QLSM_NETWORK_RULES_CONFIG:-/etc/qlsm/network-rules.json}"
IPTABLES="${QLSM_IPTABLES:-iptables}"
IPTABLES_RESTORE="${QLSM_IPTABLES_RESTORE:-iptables-restore}"
SYSCTL="${QLSM_SYSCTL:-sysctl}"
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

python3 - "$CONFIG_PATH" "$TMP_DIR" <<'PY'
import json
import pathlib
import sys

config_path = pathlib.Path(sys.argv[1])
tmp_dir = pathlib.Path(sys.argv[2])


def fail(message):
    raise SystemExit(message)


try:
    data = json.loads(config_path.read_text())
except Exception as exc:
    fail(f"Invalid QLSM network config: {exc}")


def ports(section, key):
    value = data.get(section, {}).get(key, [])
    if not isinstance(value, list):
        fail(f"{section}.{key} must be a list")
    cleaned = []
    for item in value:
        if not isinstance(item, int):
            fail(f"{section}.{key} contains non-integer port: {item!r}")
        if item < 1 or item > 65535:
            fail(f"{section}.{key} contains out-of-range port: {item}")
        cleaned.append(item)
    return sorted(set(cleaned))


outputs = {
    "filter_udp_accept": ports("filter", "udp_accept"),
    "filter_tcp_accept": ports("filter", "tcp_accept"),
    "lan_rate_udp_ports": ports("lan_rate", "udp_ports"),
}

for name, values in outputs.items():
    (tmp_dir / name).write_text("".join(f"{value}\n" for value in values))
PY

ensure_chain() {
  local table="$1"
  local chain="$2"
  "$IPTABLES" -w -t "$table" -N "$chain" 2>/dev/null || true
}

ensure_hook() {
  local table="$1"
  local source="$2"
  local chain="$3"
  "$IPTABLES" -w -t "$table" -C "$source" -j "$chain" 2>/dev/null ||
    "$IPTABLES" -w -t "$table" -I "$source" 1 -j "$chain"
}

# Ensure chains and hooks exist before we restore into them
ensure_chain filter QLSM-INPUT
ensure_hook filter INPUT QLSM-INPUT

ensure_chain nat QLSM-LANRATE-PREROUTING
ensure_chain nat QLSM-LANRATE-POSTROUTING
ensure_chain nat QLSM-LANRATE-INPUT
ensure_hook nat PREROUTING QLSM-LANRATE-PREROUTING
ensure_hook nat POSTROUTING QLSM-LANRATE-POSTROUTING
ensure_hook nat INPUT QLSM-LANRATE-INPUT

# Build filter table ruleset and apply atomically — no gap where chain is empty
{
  echo "*filter"
  echo ":QLSM-INPUT - [0:0]"
  echo "-F QLSM-INPUT"
  while read -r port; do
    [ -n "$port" ] || continue
    echo "-A QLSM-INPUT -p udp --dport $port -j ACCEPT"
  done < "$TMP_DIR/filter_udp_accept"
  while read -r port; do
    [ -n "$port" ] || continue
    echo "-A QLSM-INPUT -p tcp --dport $port -j ACCEPT"
  done < "$TMP_DIR/filter_tcp_accept"
  echo "COMMIT"
} | "$IPTABLES_RESTORE" --noflush

# Apply sysctl before nat restore
if [ -s "$TMP_DIR/lan_rate_udp_ports" ]; then
  "$SYSCTL" -w net.ipv4.conf.all.route_localnet=1
  "$SYSCTL" -w net.ipv4.conf.default.route_localnet=1
  "$SYSCTL" -w net.ipv4.conf.lo.route_localnet=1
fi

# Build nat table ruleset and apply atomically — no gap where chains are empty
{
  echo "*nat"
  echo ":QLSM-LANRATE-PREROUTING - [0:0]"
  echo ":QLSM-LANRATE-POSTROUTING - [0:0]"
  echo ":QLSM-LANRATE-INPUT - [0:0]"
  echo "-F QLSM-LANRATE-PREROUTING"
  echo "-F QLSM-LANRATE-POSTROUTING"
  echo "-F QLSM-LANRATE-INPUT"
  if [ -s "$TMP_DIR/lan_rate_udp_ports" ]; then
    echo "-A QLSM-LANRATE-INPUT -d 127.0.0.1 -j SNAT --to-source 127.0.0.1"
  fi
  while read -r port; do
    [ -n "$port" ] || continue
    echo "-A QLSM-LANRATE-PREROUTING -p udp --dport $port -j DNAT --to-destination 127.0.0.1"
    echo "-A QLSM-LANRATE-POSTROUTING -p udp -d 127.0.0.1 --dport $port -j SNAT --to-source 127.0.0.1"
  done < "$TMP_DIR/lan_rate_udp_ports"
  echo "COMMIT"
} | "$IPTABLES_RESTORE" --noflush
